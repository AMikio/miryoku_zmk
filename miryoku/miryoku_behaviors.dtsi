/ {
  behaviors {
    u_mt: u_mt {
      compatible = "zmk,behavior-hold-tap";
      #binding-cells = <2>;
      tapping-term-ms = <U_TAPPING_TERM>;
      flavor = "tap-preferred";
      bindings = <&kp>, <&kp>;
    };
    u_lt: u_lt {
      compatible = "zmk,behavior-hold-tap";
      #binding-cells = <2>;
      tapping-term-ms = <U_TAPPING_TERM>;
      flavor = "tap-preferred";
      bindings = <&mo>, <&kp>;
    };
    bspc_del: backspace_delete {
      compatible = "zmk,behavior-mod-morph";
      #binding-cells = <0>;
      bindings = <&kp BACKSPACE>, <&kp DELETE>;
      mods = <(MOD_LSFT|MOD_RSFT)>;
    };
    dt_esc_game: dt_esc_to_game_layer {
      compatible = "zmk,behavior-tap-dance";
      #binding-cells = <0>;
      tapping-term-ms = <300>;
      bindings = <&kp ESC>, <&to U_GAME>;
    };
    dt_esc_base: dt_esc_to_base_layer {
      compatible = "zmk,behavior-tap-dance";
      #binding-cells = <0>;
      tapping-term-ms = <300>;
      bindings = <&kp ESC>, <&to U_BASE>;
    };
    ht_to_kp: ht_to_kp {
      compatible = "zmk,behavior-hold-tap";
      #binding-cells = <2>;
      tapping-term-ms = <U_TAPPING_TERM>;
      flavor = "tap-preferred";
      bindings = <&to>, <&kp>;
    };

    // Niri WM macros — send Hyper (Ctrl+Alt+Shift+Super) + Fx so they are
    // safe (no-ops) on systems without explicit bindings.
    niri_consume: niri_consume {
      compatible = "zmk,behavior-macro";
      #binding-cells = <0>;
      wait-ms = <0>;
      tap-ms = <0>;
      bindings
        = <&macro_press &kp LCTRL &kp LALT &kp LSHFT &kp LGUI>
        , <&macro_tap &kp F1>
        , <&macro_release &kp LGUI &kp LSHFT &kp LALT &kp LCTRL>;
    };
    niri_expel: niri_expel {
      compatible = "zmk,behavior-macro";
      #binding-cells = <0>;
      wait-ms = <0>;
      tap-ms = <0>;
      bindings
        = <&macro_press &kp LCTRL &kp LALT &kp LSHFT &kp LGUI>
        , <&macro_tap &kp F2>
        , <&macro_release &kp LGUI &kp LSHFT &kp LALT &kp LCTRL>;
    };
    niri_mon_next: niri_mon_next {
      compatible = "zmk,behavior-macro";
      #binding-cells = <0>;
      wait-ms = <0>;
      tap-ms = <0>;
      bindings
        = <&macro_press &kp LCTRL &kp LALT &kp LSHFT &kp LGUI>
        , <&macro_tap &kp F3>
        , <&macro_release &kp LGUI &kp LSHFT &kp LALT &kp LCTRL>;
    };
    niri_win_mon: niri_win_mon {
      compatible = "zmk,behavior-macro";
      #binding-cells = <0>;
      wait-ms = <0>;
      tap-ms = <0>;
      bindings
        = <&macro_press &kp LCTRL &kp LALT &kp LSHFT &kp LGUI>
        , <&macro_tap &kp F4>
        , <&macro_release &kp LGUI &kp LSHFT &kp LALT &kp LCTRL>;
    };
    niri_shrink: niri_shrink {
      compatible = "zmk,behavior-macro";
      #binding-cells = <0>;
      wait-ms = <0>;
      tap-ms = <0>;
      bindings
        = <&macro_press &kp LCTRL &kp LALT &kp LSHFT &kp LGUI>
        , <&macro_tap &kp F5>
        , <&macro_release &kp LGUI &kp LSHFT &kp LALT &kp LCTRL>;
    };
    niri_grow: niri_grow {
      compatible = "zmk,behavior-macro";
      #binding-cells = <0>;
      wait-ms = <0>;
      tap-ms = <0>;
      bindings
        = <&macro_press &kp LCTRL &kp LALT &kp LSHFT &kp LGUI>
        , <&macro_tap &kp F6>
        , <&macro_release &kp LGUI &kp LSHFT &kp LALT &kp LCTRL>;
    };
  };
};
